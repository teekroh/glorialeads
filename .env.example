# Copy to `.env.local` and fill in. Never commit real secrets.

# --- Admin / dashboard (production)
# Use the same value for both. Required in production for routes protected by `requireAdminApiKey`
# (e.g. Cal webhook when CAL_WEBHOOK_SECRET is unset, campaign launch, dev tools).
# `NEXT_PUBLIC_*` is exposed to the browser — use only for a trusted internal dashboard.
ADMIN_API_KEY=
NEXT_PUBLIC_ADMIN_API_KEY=

# --- Cal.com
CAL_WEBHOOK_SECRET=

# --- Booking / outreach (see config/outreachConfig.ts, bookingCopy.ts)
BOOKING_LINK=
NEXT_PUBLIC_BOOKING_LINK=
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=
OUTREACH_REPLY_TO_EMAIL=
DRY_RUN=true
APP_BASE_URL=http://localhost:3000
