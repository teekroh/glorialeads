# Copy to `.env.local` and fill in real values. Never commit real secrets.

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase Postgres connection string (Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# ─── Admin / dashboard auth ──────────────────────────────────────────────────
# Required in production for routes protected by `requireAdminApiKey`
# (campaign launch, dry-run toggle, voice-training POSTs, dev/sim tools).
# Use the same value for both; NEXT_PUBLIC_* exposes it to the browser (trusted internal dashboard only).
ADMIN_API_KEY=
NEXT_PUBLIC_ADMIN_API_KEY=

# ─── Cal.com ─────────────────────────────────────────────────────────────────
# Shared secret — must match the webhook secret set in Cal.com → Webhooks.
CAL_WEBHOOK_SECRET=

# ─── Outreach: booking + email ────────────────────────────────────────────────
# Public Cal.com scheduling link embedded in outreach copy.
BOOKING_LINK=
NEXT_PUBLIC_BOOKING_LINK=

# Resend transactional email
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=
OUTREACH_REPLY_TO_EMAIL=
# Optional — meeting-booked alerts (defaults to OUTREACH_REPLY_TO_EMAIL).
OWNER_NOTIFY_EMAIL=
# Optional: personal sign-off appended to every outreach email body.
OUTREACH_EMAIL_SIGNATURE=
# Optional: override the "To" address for test sends (e.g. your own inbox).
OUTREACH_TEST_TO=

# Dry-run mode — when true Resend does NOT deliver (messages logged as dry_run).
# Dashboard can override the effective value via DashboardRuntimeConfig in the DB.
DRY_RUN=true
# Production safety gate: must be "true" to allow the dashboard to disable dry-run
# while DRY_RUN=true is set in the environment.
ALLOW_DASHBOARD_LIVE_SEND=

# Canonical origin — used to build absolute URLs (e.g. for owner-notify links).
APP_BASE_URL=http://localhost:3000

# ─── Outreach limits (optional) ───────────────────────────────────────────────
# Max first-touch sends per calendar day (default 20 if unset).
DAILY_SEND_LIMIT=
# Max sends per campaign launch batch (default 10 if unset).
CAMPAIGN_SEND_LIMIT=

# ─── Claude / Anthropic ──────────────────────────────────────────────────────
# Required for AI-generated copy, inbound classification, voice training.
ANTHROPIC_API_KEY=
# Optional model override (default claude-sonnet-4-20250514). See https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_MODEL=
# Set to "true" to disable all Claude calls and use template copy only.
CLAUDE_COPY_DISABLED=
# Optional multi-line voice override injected into every Claude prompt.
GLORIA_VOICE_GUIDELINES=

# Auto-reply: send AI-drafted reply without review when confidence ≥ threshold.
CLAUDE_AUTO_SEND=
CLAUDE_AUTO_SEND_MIN_CONFIDENCE=
# Minimum confidence to auto-book a meeting from inbound reply.
AUTO_BOOKING_MIN_CONFIDENCE=
# Minimum confidence to auto-reply to a generic inbound.
AUTO_REPLY_MIN_CONFIDENCE=
# Minimum confidence to auto-send a pricing reply.
AUTO_SEND_PRICING_MIN_CONFIDENCE=
AUTO_SEND_PRICING_REPLY=
# Fallback Cal.com link when suggested-time logic has no open slots.
AUTO_SUGGESTED_TIME_FALLBACK_CAL_LINK=
AUTO_SUGGESTED_TIME_MIN_CONFIDENCE=

# ─── Claude inbound classifier refinement (optional) ─────────────────────────
# Call Claude to re-classify when rule-based confidence is below threshold.
CLAUDE_CLASSIFIER_REFINE_DISABLED=
CLAUDE_REFINE_RULE_CONFIDENCE_BELOW=

# ─── Google Calendar (auto-booking) ──────────────────────────────────────────
# Service-account credentials JSON (base64-encoded or raw JSON string).
GOOGLE_CALENDAR_CREDENTIALS_JSON=
# The calendar ID to create events on (e.g. primary or a shared calendar address).
GOOGLE_CALENDAR_ID=
# Email to impersonate for domain-wide delegation (leave blank if using service account directly).
GOOGLE_CALENDAR_IMPERSONATE=
# Meeting slot length in minutes (default 60).
GOOGLE_CALENDAR_SLOT_MINUTES=

# ─── Enrichment / geocoding (optional) ───────────────────────────────────────
# Nominatim reverse-geocoding — set to app name + contact email per usage policy.
NOMINATIM_USER_AGENT=
# Google Places API key (for address confidence pass).
GOOGLE_PLACES_API_KEY=
# Google Custom Search Engine (for lead enrichment).
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ─── Locale / timezone ───────────────────────────────────────────────────────
# IANA timezone name for scheduling (default America/New_York).
BUSINESS_TIMEZONE=
# Language override for outreach copy (default "en").
BOOK_LANG=

# ─── Scheduled follow-up dispatch (Vercel Cron) ───────────────────────────────
# Protect GET /api/cron/outreach-dispatch — use the same secret in Vercel Cron headers.
CRON_SECRET=
